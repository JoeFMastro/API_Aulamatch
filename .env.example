# Variables de entorno — Ejemplo
# Copiar este archivo a .env y completar con valores reales
# NUNCA commitear el archivo .env

# ── Servidor ──────────────────────────────
NODE_ENV=development
PORT=3000

# ── Base de datos PostgreSQL ──────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aulamatch
DB_USER=aulamatch_user
DB_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO

# ── JWT / Autenticación ───────────────────
JWT_SECRET=CAMBIAR_POR_SECRETO_SEGURO
JWT_EXPIRES_IN=24h

# ── Docker (solo para entorno local) ──────
POSTGRES_DB=aulamatch
POSTGRES_USER=aulamatch_user
POSTGRES_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO
