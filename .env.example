# ──────────────────────────────────────────────────────────────
# AulaMatch — Archivo de ejemplo de Variables de Entorno (.env)
# Copiar este archivo a ".env" en la raíz del proyecto y editar.
# NUNCA incluir el archivo ".env" real en el control de versiones (Git).
# ──────────────────────────────────────────────────────────────

# ── Entorno y Servidor ────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Puertos expuestos en el Host local ───────────────────────
# Cambiar estos valores si los puertos 5432 o 3001 ya están ocupados en tu máquina local.
HOST_DB_PORT=5432
HOST_BACKEND_PORT=3001

# ── Base de Datos (PostgreSQL - Docker / Producción) ──────────
POSTGRES_DB=aulamatch
POSTGRES_USER=aulamatch_user
POSTGRES_PASSWORD=cambiar_por_un_password_seguro

# ── Conexión a Base de Datos (Backend) ────────────────────────
# DATABASE_URL: string de conexión directo. Usado por defecto por el backend si está definido.
# Para desarrollo local con docker compose, el host es "db" (nombre del servicio en docker-compose).
# Para desarrollo local directo sin Docker, usar "localhost" en vez de "db".
DATABASE_URL=postgresql://aulamatch_user:cambiar_por_un_password_seguro@db:5432/aulamatch

# Variables individuales de conexión (fallback si DATABASE_URL no está definida)
DB_HOST=db
DB_PORT=5432
DB_NAME=aulamatch
DB_USER=aulamatch_user
DB_PASSWORD=cambiar_por_un_password_seguro

# ── Seguridad y Autenticación (JWT) ──────────────────────────
JWT_SECRET=cambiar_por_un_secreto_super_seguro_y_largo_de_32_caracteres_minimo
JWT_EXPIRES_IN=24h
