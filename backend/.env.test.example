# ──────────────────────────────────────────────────────────────
# AulaMatch — Variables de Entorno para Tests (.env.test.example)
# Copiar este archivo a ".env.test" en esta misma carpeta y editar si es necesario.
# ──────────────────────────────────────────────────────────────

NODE_ENV=test
PORT=3002

# Conexión a Base de Datos de Test (PostgreSQL)
# Apunta a localhost porque los tests se ejecutan en el host local contra el puerto expuesto del contenedor de Docker.
DATABASE_URL=postgresql://aulamatch_user:cambiar_por_un_password_seguro@localhost:5432/aulamatch_test

# Alternativa con variables individuales (fallback)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aulamatch_test
DB_USER=aulamatch_user
DB_PASSWORD=cambiar_por_un_password_seguro

# Seguridad y Autenticación (JWT) para Tests
JWT_SECRET=secreto_de_test_muy_largo_y_seguro_minimo_32_caracteres
JWT_EXPIRES_IN=1h
